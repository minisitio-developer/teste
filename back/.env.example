# ========================================
# CONFIGURAÇÕES DE AMBIENTE - MINISITIO
# ========================================
# Copie este arquivo para .env e configure os valores

# ========== SERVIDOR ==========
# Porta do servidor backend
PORT=3032

# Ambiente (development, staging, production)
NODE_ENV=development

# ========== BANCO DE DADOS ==========
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=sua_senha_aqui
DB_NAME=minisitio_db
DB_PORT=3306

# ========== CORS E SEGURANÇA ==========
# Lista de domínios permitidos (separados por vírgula)
# Exemplo: http://localhost:3000,https://meufrontend.com,https://admin.meufrontend.com
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,https://meufrontend.com,https://admin.meufrontend.com,https://www.meufrontend.com

# ========== JWT E AUTENTICAÇÃO ==========
# Chave secreta para JWT (use uma string longa e aleatória)
JWT_SECRET=sua_chave_secreta_muito_longa_e_aleatoria_aqui

# Tempo de expiração do token (ex: 24h, 7d)
JWT_EXPIRE=24h

# ========== EMAIL / NODEMAILER ==========
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=seu_email@gmail.com
SMTP_PASSWORD=sua_senha_app_aqui
SMTP_FROM=noreply@meufrontend.com

# ========== MERCADO PAGO ==========
MERCADOPAGO_ACCESS_TOKEN=seu_token_aqui
MERCADOPAGO_PUBLIC_KEY=sua_chave_publica_aqui

# ========== UPLOAD E ARQUIVOS ==========
# Tamanho máximo de arquivo permitido (em bytes)
MAX_FILE_SIZE=52428800

# Pasta para uploads
UPLOAD_PATH=./public/upload

# ========== SSL/HTTPS (Produção) ==========
# Descomente e configure para usar HTTPS em produção
# SSL_KEY_PATH=./certificados/code.key
# SSL_CERT_PATH=./certificados/code.crt
# SSL_PORT=3032

# ========== LOGS ==========
# Nível de logging (debug, info, warn, error)
LOG_LEVEL=info

# ========== SEGURANÇA ADICIONAL ==========
# Ativar helmet.js para headers de segurança
USE_HELMET=true

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ========== FRONTEND ==========
# URL do frontend para redirecionamentos
FRONTEND_URL=http://localhost:3000

# ========== CACHE ==========
# Tempo de cache em segundos
CACHE_TTL=3600
