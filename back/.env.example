# ==============================================
# Banco de Dados (obrigatório)
# ==============================================
DB_HOST=localhost
DB_PORT=3307
DB_USER=root
DB_PASSWORD=CHANGE_THIS_TO_A_STRONG_PASSWORD
DB_NAME=minisitio_local

# OU use DATABASE_URL (Railway):
# DATABASE_URL=mysql://user:pass@host:port/dbname

# ==============================================
# Backend (obrigatório)
# ==============================================
PORT=3032
NODE_ENV=development

# ==============================================
# Segurança (obrigatório - mínimo 32 caracteres)
# ==============================================
API_KEY=CHANGE_THIS_TO_A_RANDOM_STRING_MIN_32_CHARS
API_SECRET=CHANGE_THIS_TO_A_RANDOM_STRING_MIN_64_CHARS_FOR_IDEAL_SECURITY

# ==============================================
# JWT Authentication (obrigatório)
# ==============================================
JWT_SECRET=CHANGE_THIS_TO_A_RANDOM_STRING_MIN_64_CHARS

# ==============================================
# Mercado Pago
# ==============================================
MP_ACCESS_TOKEN=CHANGE_THIS_WITH_YOUR_MP_ACCESS_TOKEN
MP_PUBLIC_KEY=CHANGE_THIS_WITH_YOUR_MP_PUBLIC_KEY
MP_WEBHOOK_SECRET=CHANGE_THIS_WITH_YOUR_MP_WEBHOOK_SECRET

# ==============================================
# CORS
# ==============================================
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# ==============================================
# SMTP Email
# ==============================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=CHANGE_THIS_WITH_YOUR_EMAIL
SMTP_PASS=CHANGE_THIS_WITH_YOUR_APP_PASSWORD

# ==============================================
# Admin Seed (opcional - cria admin automaticamente)
# ==============================================
# ADMIN_CNPJ=12345678901234
# ADMIN_SENHA=UmaSenhaForte123!
# ADMIN_EMAIL=admin@sistema.com
